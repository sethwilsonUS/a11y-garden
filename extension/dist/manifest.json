{
  "manifest_version": 3,
  "name": "A11y Garden Live Scan",
  "version": "0.1.0",
  "description": "Scan the current tab with A11y Garden and open a private hosted result.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "https://a11ygarden.org/*",
    "https://www.a11ygarden.org/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "A11y Garden Live Scan",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://a11ygarden.org/results/*",
        "https://www.a11ygarden.org/results/*",
        "http://localhost:3000/results/*",
        "http://127.0.0.1:3000/results/*"
      ],
      "js": ["a11y-garden-bridge.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["vendor/axe.min.js", "vendor/HTMLCS.js", "vendor/ace.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
