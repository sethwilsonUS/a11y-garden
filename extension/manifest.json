{
  "manifest_version": 3,
  "name": "A11y Garden",
  "version": "0.2.0",
  "description": "Scan the current tab with A11y Garden and view private results locally in Chrome.",
  "permissions": ["activeTab", "scripting", "storage", "tabs", "unlimitedStorage"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "A11y Garden",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "commands": {
    "scan-current-tab": {
      "suggested_key": {
        "default": "Alt+Shift+A",
        "mac": "Alt+Shift+A"
      },
      "description": "Scan the current tab with A11y Garden"
    }
  }
}
